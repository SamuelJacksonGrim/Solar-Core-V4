            status.fault_code = max(status.fault_code, 1)
        status.fault_code = max(status.fault_code, self.thermal.evaluate(status))
        self.enforce_buffer_limits(status)
        self.lora.send_packet(asdict(status), port=NexusConfig.LORA_HEALTH_PORT)
        return status
