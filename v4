class ZincIonSafeguard:
    def __init__(self, window=NexusConfig.RESISTANCE_WINDOW, threshold=NexusConfig.DENDRITE_THRESHOLD):
        self.window = window; self.threshold = threshold
        self.resistance_history: List[float] = []
    def check_for_dendrites(self, resistance: float) -> bool:
        self.resistance_history.append(resistance)
        if len(self.resistance_history) < self.window: return False
        recent = self.resistance_history[-self.window:]
        avg = sum(recent) / len(recent)
        if avg > 0 and resistance < (avg * self.threshold):
            log.warning(f"DENDRITE RISK: {resistance:.4f}Ohm dropped below {self.threshold*100:.0f}% of avg {avg:.4f}Ohm")
            return True
        return False
    def reset(self): self.resistance_history.clear()

class ThermalManager:
    @staticmethod
    def evaluate(status: BatteryStatus) -> int:
        temp = status.temperature
        if NexusConfig.TEMP_OPTIMAL_LOW <= temp <= NexusConfig.TEMP_OPTIMAL_HIGH: return 0
        if temp > NexusConfig.TEMP_CRITICAL_HIGH or temp < NexusConfig.TEMP_CRITICAL_LOW:
            log.critical(f"THERMAL CRITICAL: {temp}C on {status.block_id}"); return 3
        if temp > NexusConfig.TEMP_OPTIMAL_HIGH: log.warning(f"Thermal drift HIGH: {temp}C")
        elif temp < NexusConfig.TEMP_OPTIMAL_LOW: log.warning(f"Thermal drift LOW: {temp}C")
        return 2

