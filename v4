        if status.soc > NexusConfig.SOC_UPPER_LIMIT:
            self.can.send_command(self.block_id, "LIMIT_CHARGE"); return "charge_limited"
        elif status.soc < NexusConfig.SOC_LOWER_LIMIT:
            self.can.send_command(self.block_id, "DISCONNECT_LOAD"); return "load_disconnected"
        return "normal"
